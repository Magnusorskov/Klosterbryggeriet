@page "/importer-csv"
@using BlazorApp.Models
@using BlazorApp.Models.Dtos
@using BlazorApp.Services
@rendermode InteractiveServer

@inject ICsvUploadService CsvUploadService
@inject ProductService ProductService
@inject CategoryService CategoryService

<PageTitle>Importer CSV</PageTitle>

<section class="csv-page">
    <header class="csv-header">
        <p class="csv-eyebrow">Import</p>
        <h1 class="csv-title">Importer CSV</h1>
        <p class="csv-lede">Upload en eksportfil fra Octopus for at synkronisere produkternes tilgængelighed.</p>
    </header>

    <label class="dropzone">
        <InputFile OnChange="HandleFileSelected" accept=".csv"
                   style="position:absolute; inset:0; width:100%; height:100%; opacity:0; cursor:pointer; z-index:1;" />
        <div class="dropzone-content">
            <span class="dropzone-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                    <polyline points="17 8 12 3 7 8" />
                    <line x1="12" y1="3" x2="12" y2="15" />
                </svg>
            </span>
            <p class="dropzone-title">Træk og slip din CSV-fil her</p>
            <p class="dropzone-sub">eller klik for at vælge en fil fra din computer</p>
            <span class="dropzone-pill">Understøttede formater: .csv</span>
        </div>
    </label>

    @if (selectedFile is not null)
    {
        <div class="selected-card">
            <div class="selected-info">
                <span class="file-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z" />
                        <polyline points="13 2 13 9 20 9" />
                    </svg>
                </span>
                <div class="selected-text">
                    <p class="selected-label">Valgt fil</p>
                    <p class="selected-name">@selectedFile.Name</p>
                </div>
            </div>
            <button class="btn-upload" @onclick="UploadCsv" disabled="@isUploading">
                @if (isUploading)
                {
                    <span class="spinner" aria-hidden="true"></span>
                    <span>Uploader...</span>
                }
                else
                {
                    <span>Upload</span>
                }
            </button>
        </div>
    }

    @if (errorMessage is not null)
    {
        <div class="status-card status-error">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="10" />
                <line x1="12" y1="8" x2="12" y2="12" />
                <line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
            @errorMessage
        </div>
    }

    <div class="info-card">
        <strong>Eksportér fra Octopus:</strong>
        <span>Gå til Produkter → Eksportér → Vælg CSV-format og download filen.</span>
    </div>

    @if (_needsAttention.Count > 0)
    {
        <section class="attention-block">
            <header class="attention-header">
                <h2 class="attention-title">Nye produkter til gennemgang</h2>
                <p class="attention-sub">
                    Disse produkter blev lige oprettet fra CSV-importen. Udfyld felterne og klik <strong>Færdiggør</strong>. Manuelle felter er påkrævede når <em>I brug</em> er slået til.
                </p>
            </header>

            @if (_finishSummary is not null)
            {
                <div class="finish-summary @(_finishSummary.HasErrors ? "finish-summary-warn" : "finish-summary-ok")">
                    @_finishSummary.Message
                </div>
            }

            <div class="attention-rows">
                @foreach (var row in _needsAttention)
                {
                    var p = row.Product;
                    var inUse = p.InUse;
                    <div class="attention-row @(row.Errors.Count > 0 ? "attention-row-error" : "")">
                        <div class="attention-row-head">
                            <span class="row-id">#@p.OctopusId</span>
                            <span class="row-title">@(string.IsNullOrWhiteSpace(p.OctopusTitle) ? "—" : p.OctopusTitle)</span>
                            <span class="row-stock">Disponibel: <strong>@p.Available</strong></span>
                        </div>

                        <div class="row-fields row-fields-manual">
                            <label class="row-field">
                                <span class="row-field-label">
                                    Kategori@(inUse ? "*" : "")
                                    @if (IsNewCategory(p.Category))
                                    {
                                        <span class="new-category-chip">ny</span>
                                    }
                                </span>
                                <input class="row-input @ErrClass(row, "Category")"
                                       list="importer-categories"
                                       placeholder="Vælg eller skriv ny"
                                       @bind="p.Category" @bind:event="oninput" />
                            </label>
                            <label class="row-field">
                                <span class="row-field-label">PDF-titel@(inUse ? "*" : "")</span>
                                <input class="row-input @ErrClass(row, "PdfTitle")"
                                       @bind="p.PdfTitle" @bind:event="oninput" />
                            </label>
                            <label class="row-field row-field-narrow">
                                <span class="row-field-label">Kasse/Kolli@(inUse ? "*" : "")</span>
                                <input class="row-input @ErrClass(row, "KegCollar")" type="number"
                                       @bind="row.KegCollarInput" />
                            </label>
                            <label class="row-field row-field-narrow">
                                <span class="row-field-label">Str (L)@(inUse ? "*" : "")</span>
                                <input class="row-input @ErrClass(row, "Str")" type="number" step="0.01"
                                       @bind="p.Str" />
                            </label>
                            <label class="row-field row-field-narrow">
                                <span class="row-field-label">Alkohol %@(inUse ? "*" : "")</span>
                                <input class="row-input @ErrClass(row, "Alcohol")" type="number" step="0.1"
                                       @bind="p.Alcohol" />
                            </label>
                            <label class="row-field row-field-narrow">
                                <span class="row-field-label">Pris/enhed@(inUse ? "*" : "")</span>
                                <input class="row-input @ErrClass(row, "PricePrUnit")" type="number" step="0.01"
                                       @bind="p.PricePrUnit" />
                            </label>
                        </div>

                        <div class="row-fields row-fields-shop">
                            <div class="row-fields-shop-label">
                                Webshop <span class="row-fields-shop-hint">(valgfrit — udfyldes hvis produktet er på webshoppen)</span>
                            </div>
                            <label class="row-field row-field-narrow">
                                <span class="row-field-label">Web ID</span>
                                <input class="row-input" type="number" @bind="p.WebId" />
                            </label>
                            <label class="row-field row-field-narrow">
                                <span class="row-field-label">Variant 1</span>
                                <input class="row-input" type="number" @bind="p.VariantId1" />
                            </label>
                            <label class="row-field row-field-narrow">
                                <span class="row-field-label">Variant 2</span>
                                <input class="row-input" type="number" @bind="p.VariantId2" />
                            </label>
                        </div>

                        <div class="row-toggles">
                            <label class="row-toggle">
                                <input type="checkbox" @bind="p.InUse" />
                                <span><strong>I brug</strong> — vises på prislisten og opdateres på webshoppen</span>
                            </label>
                            <label class="row-toggle">
                                <input type="checkbox" @bind="p.HalfKolli" />
                                <span>Halv kasse tilgængelig</span>
                            </label>
                        </div>

                        @if (row.Errors.Count > 0)
                        {
                            <ul class="row-errors">
                                @foreach (var err in row.Errors)
                                {
                                    <li>@err</li>
                                }
                            </ul>
                        }
                    </div>
                }
            </div>

            <div class="attention-footer">
                <button class="btn-finish" @onclick="FinishAll" disabled="@_finishing">
                    @(_finishing ? "Gemmer…" : "Færdiggør")
                </button>
            </div>
        </section>
    }

    @if (_lastResult is not null)
    {
        <section class="receipt-block">
            <header class="receipt-header">
                <h2 class="receipt-title">Seneste import</h2>
                <p class="receipt-meta">
                    @_lastResult.FileName · @_lastResult.ImportedAt.ToString("dd.MM.yyyy HH:mm")
                    · @_lastResult.RowsParsed rækker læst
                    @if (_lastResult.RowsSkipped > 0)
                    {
                        <span> · @_lastResult.RowsSkipped sprunget over</span>
                    }
                </p>
                <p class="receipt-counts">
                    @_lastResult.Updated.Count opdateret
                    · @_lastResult.Created.Count ny@(_lastResult.Created.Count == 1 ? "t" : "e")
                    · @_lastResult.StatusFlipCount status-skift
                </p>
            </header>

            @if (_lastResult.Updated.Count == 0 && _lastResult.Created.Count == 0)
            {
                <p class="receipt-empty">Ingen ændringer i denne import.</p>
            }
            else
            {
                <ul class="diff-list">
                    @foreach (var c in _lastResult.Created)
                    {
                        <li class="diff-row diff-add">
                            <span class="diff-marker">+</span>
                            <span class="diff-id">#@c.OctopusId</span>
                            <span class="diff-title">@(string.IsNullOrWhiteSpace(c.OctopusTitle) ? "—" : c.OctopusTitle)</span>
                            <span class="diff-detail">Disponibel=@c.Available · oprettet som «Ikke i brug»</span>
                        </li>
                    }
                    @foreach (var u in _lastResult.Updated)
                    {
                        <li class="diff-row @DiffRowClass(u)">
                            <span class="diff-marker">~</span>
                            <span class="diff-id">#@u.OctopusId</span>
                            <span class="diff-title">@(string.IsNullOrWhiteSpace(u.OctopusTitle) ? "—" : u.OctopusTitle)</span>
                            <span class="diff-detail">
                                @u.PreviousAvailable → @u.NewAvailable
                                @if (u.StatusFlipped)
                                {
                                    <span class="diff-status"> (@StatusLabel(u.PreviousStatus) → @StatusLabel(u.NewStatus))</span>
                                }
                            </span>
                        </li>
                    }
                </ul>
            }

            @if (_lastResult.Warnings.Count > 0)
            {
                <div class="receipt-warnings">
                    <p class="receipt-warnings-title">Advarsler</p>
                    <ul>
                        @foreach (var w in _lastResult.Warnings)
                        {
                            <li>@w</li>
                        }
                    </ul>
                </div>
            }
        </section>
    }
</section>

<datalist id="importer-categories">
    @foreach (var c in _categories)
    {
        <option value="@c.Name" />
    }
</datalist>

@code {
    private IBrowserFile? selectedFile;
    private bool isUploading;
    private string? errorMessage;

    private CsvImportResult? _lastResult;
    private List<EditRow> _needsAttention = [];
    private HashSet<int> _recentlyCreatedIds = [];
    private bool _finishing;
    private FinishSummary? _finishSummary;
    private List<Category> _categories = [];

    protected override async Task OnInitializedAsync()
    {
        _categories = await CategoryService.GetAllAsync();
    }

    private bool IsNewCategory(string? name) =>
        !string.IsNullOrWhiteSpace(name)
        && !_categories.Any(c => string.Equals(c.Name, name!.Trim(), StringComparison.OrdinalIgnoreCase));

    private class EditRow
    {
        public required Product Product { get; set; }
        public List<string> Errors { get; set; } = [];
        public HashSet<string> FieldErrors { get; set; } = [];

        public int KegCollarInput
        {
            get => Product.KegCollar ?? 0;
            set => Product.KegCollar = value == 0 ? null : value;
        }
    }

    private record FinishSummary(string Message, bool HasErrors);

    private async Task ReloadNeedsAttention()
    {
        if (_recentlyCreatedIds.Count == 0)
        {
            _needsAttention = [];
            return;
        }
        var all = await ProductService.ListProducts();
        _needsAttention = all
            .Where(p => _recentlyCreatedIds.Contains(p.OctopusId))
            .OrderBy(p => p.OctopusId)
            .Select(p => new EditRow { Product = CloneProduct(p) })
            .ToList();
    }

    private static Product CloneProduct(Product p) => new()
    {
        OctopusId    = p.OctopusId,
        WebId        = p.WebId,
        WebTitle     = p.WebTitle,
        PdfTitle     = p.PdfTitle,
        OctopusTitle = p.OctopusTitle,
        Available    = p.Available,
        KegCollar    = p.KegCollar,
        Str          = p.Str,
        Alcohol      = p.Alcohol,
        PricePrUnit  = p.PricePrUnit,
        Category     = p.Category,
        VariantId1   = p.VariantId1,
        VariantId2   = p.VariantId2,
        InUse        = p.InUse,
        HalfKolli    = p.HalfKolli,
    };

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (!file.Name.EndsWith(".csv", StringComparison.OrdinalIgnoreCase))
        {
            selectedFile = null;
            errorMessage = "Kun CSV-filer er tilladt.";
            return;
        }

        selectedFile = file;
        errorMessage = null;
    }

    private async Task UploadCsv()
    {
        if (selectedFile is null) return;

        isUploading = true;
        errorMessage = null;
        _finishSummary = null;

        try
        {
            await using var stream = selectedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            _lastResult = await CsvUploadService.UploadCsvAsync(stream, selectedFile.Name);
            _recentlyCreatedIds = _lastResult.Created.Select(c => c.OctopusId).ToHashSet();
            selectedFile = null;
            await ReloadNeedsAttention();
        }
        catch (Exception ex)
        {
            errorMessage = $"Fejl under upload: {ex.Message}";
        }
        finally
        {
            isUploading = false;
        }
    }

    private async Task FinishAll()
    {
        _finishing = true;
        _finishSummary = null;

        foreach (var row in _needsAttention)
        {
            ValidateRow(row);
        }

        var savable = _needsAttention.Where(r => r.Errors.Count == 0).ToList();

        // Any savable row that references a Category name we don't yet have an entity for
        // → create a bare-bones Category so the product will appear on the price list.
        // Dedup by name (case-insensitive) to avoid inserting duplicates within one click.
        var existingNames = _categories.Select(c => c.Name).ToHashSet(StringComparer.OrdinalIgnoreCase);
        var newCategoryNames = savable
            .Select(r => (r.Product.Category ?? "").Trim())
            .Where(n => n.Length > 0 && !existingNames.Contains(n))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
        foreach (var name in newCategoryNames)
        {
            await CategoryService.CreateAsync(new Category { Name = name, PriceLabel = "" });
        }
        if (newCategoryNames.Count > 0)
        {
            _categories = await CategoryService.GetAllAsync();
        }

        var savedCount = 0;
        foreach (var row in savable)
        {
            try
            {
                // Normalize so the stored Category string exactly matches the entity name.
                row.Product.Category = (row.Product.Category ?? "").Trim();
                await ProductService.UpdateAsync(row.Product);
                savedCount++;
                // TODO: once the webshop integration is ready, call HostedShopService here
                // for rows where row.Product.WebId > 0.
            }
            catch (Exception ex)
            {
                row.Errors.Add($"Kunne ikke gemme: {ex.Message}");
            }
        }

        _needsAttention = _needsAttention.Where(r => r.Errors.Count > 0).ToList();

        var hasErrors = _needsAttention.Count > 0;
        _finishSummary = hasErrors
            ? new FinishSummary($"{savedCount} gemt. {_needsAttention.Count} venter på udfyldelse.", true)
            : new FinishSummary($"{savedCount} produkt{(savedCount == 1 ? "" : "er")} gemt.", false);

        _finishing = false;
    }

    private static void ValidateRow(EditRow row)
    {
        row.Errors.Clear();
        row.FieldErrors.Clear();

        if (!row.Product.InUse) return;

        var p = row.Product;
        if (string.IsNullOrWhiteSpace(p.Category)) { row.FieldErrors.Add("Category"); row.Errors.Add("Kategori er påkrævet når produktet er i brug."); }
        if (string.IsNullOrWhiteSpace(p.PdfTitle)) { row.FieldErrors.Add("PdfTitle"); row.Errors.Add("PDF-titel er påkrævet når produktet er i brug."); }
        if ((p.KegCollar ?? 0) == 0) { row.FieldErrors.Add("KegCollar"); row.Errors.Add("Kasse/Kolli er påkrævet når produktet er i brug."); }
        if (p.Str == 0) { row.FieldErrors.Add("Str"); row.Errors.Add("Størrelse er påkrævet når produktet er i brug."); }
        if (p.Alcohol == 0) { row.FieldErrors.Add("Alcohol"); row.Errors.Add("Alkohol% er påkrævet når produktet er i brug."); }
        if (p.PricePrUnit == 0) { row.FieldErrors.Add("PricePrUnit"); row.Errors.Add("Pris pr. enhed er påkrævet når produktet er i brug."); }
    }

    private static string ErrClass(EditRow row, string field) =>
        row.FieldErrors.Contains(field) ? "row-input-error" : "";

    private static string DiffRowClass(ProductChange u) =>
        u.StatusFlipped
            ? (u.NewStatus == ProductStatus.Available ? "diff-flip-up" : "diff-flip-down")
            : "diff-update";

    private static string StatusLabel(ProductStatus status) => status switch
    {
        ProductStatus.Available => "Tilgængelig",
        ProductStatus.SoldOut => "Udsolgt",
        _ => status.ToString(),
    };
}
