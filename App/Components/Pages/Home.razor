                    <path d="M8 8h8l1 12a1 1 0 0 1 -1 1h-8a1 1 0 0 1 -1 -1z" />
                    <path d="M17 10h1a2 2 0 0 1 2 2v3a2 2 0 0 1 -2 2h-1" />
                </svg>
            </span>
