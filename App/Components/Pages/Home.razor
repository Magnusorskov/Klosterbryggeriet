@page "/"
@using BlazorApp.Services
@rendermode InteractiveServer

@inject ICsvConverterService CsvConverterService
@inject IJSRuntime JS

<PageTitle>Home</PageTitle>

<h1>CSV til PDF</h1>

<InputFile id="fileInput" OnChange="HandleFileSelected" accept=".csv" style="display:none" />
<label for="fileInput" style="cursor:pointer; padding:6px 12px; border:1px solid #ccc; border-radius:4px;">
    Vælg CSV-fil
</label>

<button @onclick="ConvertToPdf" disabled="@(selectedFile is null || isConverting)">
    @(isConverting ? "Konverterer..." : "Konverter til PDF")
</button>
<PriceList Products="new List<Product>()"></PriceList>
@if (errorMessage is not null)
{
    <p style="color: red;">@errorMessage</p>
}

@code {
    private IBrowserFile? selectedFile;
    private bool isConverting;
    private string? errorMessage;

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (!file.Name.EndsWith(".csv", StringComparison.OrdinalIgnoreCase))
        {
            selectedFile = null;
            errorMessage = "Kun CSV-filer er tilladt.";
            return;
        }

        selectedFile = file;
        errorMessage = null;
    }

    private async Task ConvertToPdf()
    {
        if (selectedFile is null) return;

        isConverting = true;
        errorMessage = null;

        try
        {
            await using var stream = selectedFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            var pdfBytes = await CsvConverterService.ConvertCsvToPdfAsync(stream, selectedFile.Name);

            var pdfFileName = Path.GetFileNameWithoutExtension(selectedFile.Name) + ".pdf";
            await JS.InvokeVoidAsync("downloadFile", pdfFileName, "application/pdf", pdfBytes);
        }
        catch (Exception ex)
        {
            errorMessage = $"Fejl under konvertering: {ex.Message}";
        }
        finally
        {
            isConverting = false;
        }
    }
}
