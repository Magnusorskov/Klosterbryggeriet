@page "/"

<PageTitle>Klosterbryggeriet</PageTitle>

<section class="overview">
    <p class="overview-eyebrow">Oversigt</p>
    <h1 class="overview-title">Velkommen til Klosterbryggeriet</h1>
    <p class="overview-lede">Vælg et af værktøjerne nedenfor for at komme i gang.</p>

    <hr class="overview-divider" />

    <div class="overview-grid">
        <a class="overview-card" href="importer-csv">
            <span class="overview-card-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 7.5h-.75A2.25 2.25 0 0 0 4.5 9.75v7.5a2.25 2.25 0 0 0 2.25 2.25h7.5a2.25 2.25 0 0 0 2.25-2.25v-7.5a2.25 2.25 0 0 0-2.25-2.25h-.75m-6 3.75 3 3m0 0 3-3m-3 3V1.5m6 9h.75a2.25 2.25 0 0 1 2.25 2.25v7.5a2.25 2.25 0 0 1-2.25 2.25h-7.5a2.25 2.25 0 0 1-2.25-2.25v-.75" />
                </svg>
            </span>
            <h2 class="overview-card-title">Importer CSV</h2>
            <p class="overview-card-desc">Upload en Octopus-eksport for at opdatere produkternes tilgængelighed og lagerstatus.</p>
            <span class="overview-card-link">Gå til import <span aria-hidden="true">→</span></span>
        </a>

        <a class="overview-card" href="prisliste">
            <span class="overview-card-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 0 1 0 3.75H5.625a1.875 1.875 0 0 1 0-3.75Z" />
                </svg>
            </span>
            <h2 class="overview-card-title">Prisliste</h2>
            <p class="overview-card-desc">Gennemse og eksportér den aktuelle prisliste med produkter, kategorier og priser som PDF.</p>
            <span class="overview-card-link">Se prisliste <span aria-hidden="true">→</span></span>
        </a>

        <a class="overview-card" href="fadoel">
            <span class="overview-card-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
