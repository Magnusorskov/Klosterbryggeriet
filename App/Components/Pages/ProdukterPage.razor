@page "/produkter"
@using BlazorApp.Models
@using BlazorApp.Services
@using BlazorApp.Components
@using System.Globalization
@rendermode InteractiveServer

@inject ProductService ProductService

<PageTitle>Produkter</PageTitle>

<section class="produkter-page">
    <div class="produkter-header">
        <h1 class="produkter-title">Produkter</h1>
        <span class="produkter-count">@_products.Count i databasen</span>
    </div>

    @if (_loading)
    {
        <p class="produkter-empty">Henter produkter...</p>
    }
    else
    {
        <div class="filter-bar">
            <div class="search-box">
                <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8" />
                    <line x1="21" y1="21" x2="16.65" y2="16.65" />
                </svg>
                <input class="search-input" @bind="_search" @bind:event="oninput"
                       placeholder="Søg ID, titel, kategori…" />
                @if (!string.IsNullOrEmpty(_search))
                {
                    <button class="search-clear" @onclick="() => _search = string.Empty"
                            aria-label="Ryd søgning">
                        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="18" y1="6" x2="6" y2="18" />
                            <line x1="6" y1="6" x2="18" y2="18" />
                        </svg>
                    </button>
                }
            </div>

            <select class="filter-select" @bind="_catFilter">
                <option value="Alle">Alle kategorier</option>
                @foreach (var cat in _allCats)
                {
                    <option value="@cat">@cat</option>
                }
            </select>

            <div class="pill-group" role="group" aria-label="Lagerstatus">
                <span class="pill-group-label">Lager</span>
                @foreach (var s in _statusOptions)
                {
                    <button class="pill @(_statusFilter == s ? "pill-active" : "")"
                            @onclick="() => _statusFilter = s">@s</button>
                }
            </div>

            <span class="filter-divider" aria-hidden="true"></span>

            <div class="pill-group" role="group" aria-label="I brug">
                <span class="pill-group-label">Status</span>
                @foreach (var s in _inUseOptions)
                {
                    <button class="pill @(_inUseFilter == s ? "pill-active" : "")"
                            @onclick="() => _inUseFilter = s">@s</button>
                }
            </div>

            <div class="missing-wrap">
                <button class="missing-btn @(_missingFilters.Count > 0 ? "missing-btn-on" : "")"
                        @onclick="ToggleMissingOpen">
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
                        <line x1="12" y1="9" x2="12" y2="13" />
                        <line x1="12" y1="17" x2="12.01" y2="17" />
                    </svg>
                    Manglende felter
                    @if (_missingFilters.Count > 0)
                    {
                        <span class="missing-count">@_missingFilters.Count</span>
                    }
                </button>
                @if (_missingOpen)
                {
                    <div class="missing-backdrop" @onclick="() => _missingOpen = false"></div>
                    <div class="missing-menu" @onclick:stopPropagation>
                        <div class="missing-menu-label">Vis kun produkter hvor</div>
                        @foreach (var opt in MissingOptions)
                        {
                            var key = opt.Key;
                            <label class="missing-opt">
                                <input type="checkbox"
                                       checked="@_missingFilters.Contains(key)"
                                       @onchange="() => ToggleMissing(key)" />
                                @opt.Label
                            </label>
                        }
                        @if (_missingFilters.Count > 0)
                        {
                            <div class="missing-menu-footer">
                                <button class="missing-clear" @onclick="ClearMissing">Ryd filtre</button>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="results-line">
            Viser @FilteredProducts().Count af @_products.Count produkter
            @if (_missingFilters.Count > 0)
            {
                <span class="results-accent">· @_missingFilters.Count manglende-felt filter@(_missingFilters.Count > 1 ? "e" : "") aktive</span>
            }
        </div>

        <div class="split">
            @{
                var rows = FilteredProducts();
            }
            @* ── Left: list ───────────────────────────────────────────── *@
            <aside class="list-pane">
                <div class="list-toolbar">
                    <span class="list-toolbar-count">@rows.Count produkter</span>
                    <div class="list-sort-wrap">
                        <label for="prod-sort" class="list-sort-label">Sortér</label>
                        <select id="prod-sort" class="list-sort" @bind="_sortKey">
                            @foreach (var opt in SortOptions)
                            {
                                <option value="@opt.Key">@opt.Label</option>
                            }
                        </select>
                    </div>
                </div>

                <div class="list-rows">
                    @if (rows.Count == 0)
                    {
                        <div class="list-empty">Ingen produkter matcher de valgte filtre</div>
                    }
                    else
                    {
                        @foreach (var p in rows)
                        {
                            var soldOut = p.Status == ProductStatus.SoldOut;
                            var dotClass = !p.InUse ? "dot-off" : (soldOut ? "dot-soldout" : "dot-ok");
                            var pid = p.OctopusId;
                            <button class="list-row @(p.OctopusId == _selectedId ? "list-row-selected" : "")"
                                    @onclick="() => SelectProduct(pid)"
                                    type="button">
                                <span class="lr-id">#@p.OctopusId</span>
                                <span class="lr-main">
                                    <span class="lr-title">@p.OctopusTitle</span>
                                    <span class="lr-cat">@p.Category</span>
                                </span>
                                <span class="lr-status">
                                    <span class="status-dot @dotClass"></span>
                                    <span class="lr-avail">@p.Available</span>
                                </span>
                            </button>
                        }
                    }
                </div>
            </aside>

            @* ── Right: detail ────────────────────────────────────────── *@
            <section class="detail-pane">
                @if (_draft == null || _original == null)
                {
                    <div class="detail-empty">
                        <p class="detail-empty-eyebrow">Vælg et produkt</p>
                        <p class="detail-empty-text">Klik et produkt i listen til venstre for at se og redigere alle felter.</p>
                    </div>
                }
                else
                {
                    var d = _draft;
                    var soldOut = d.Status == ProductStatus.SoldOut;
                    var dotClass = !d.InUse ? "dot-off" : (soldOut ? "dot-soldout" : "dot-ok");
                    var dirtyCount = DirtyFieldCount();

                    <header class="detail-head">
                        <p class="detail-eyebrow">@d.Category</p>
                        <h2 class="detail-title">@d.OctopusTitle</h2>
                        <p class="detail-ids">
                            Octopus <span class="detail-id-strong">#@d.OctopusId</span>
                            <span class="detail-id-sep">·</span>
                            Web <span class="detail-id-strong">#@d.WebId</span>
                        </p>
                    </header>

                    @if (_pendingSwitchTo.HasValue)
                    {
                        <div class="dirty-prompt">
                            <span>Du har ugemte ændringer på #@_original.OctopusId.</span>
                            <button class="link-btn" @onclick="ConfirmSwitchDiscard">Forkast og skift</button>
                            <button class="link-btn link-btn-strong" @onclick="CancelSwitch">Bliv her</button>
                        </div>
                    }

                    <div class="detail-section">
                        <p class="detail-section-label">Status &amp; lager</p>
                        <div class="status-row">
                            <div class="status-tile">
                                <span class="status-dot status-dot-lg @dotClass"></span>
                                <span class="status-value">@d.Available</span>
                                <span class="status-value-label">Disponibel</span>
                            </div>

                            <button type="button"
                                    class="toggle-pill @(d.InUse ? "tp-on" : "tp-off") @(FieldDirty("InUse") ? "is-dirty" : "")"
                                    @onclick="ToggleInUse">
                                <span class="tp-dot"></span>
                                @(d.InUse ? "I brug" : "Ikke i brug")
                            </button>

                            <button type="button"
                                    class="toggle-pill @(d.HalfKolli ? "tp-half-on" : "tp-half-off") @(FieldDirty("HalfKolli") ? "is-dirty" : "")"
                                    @onclick="ToggleHalfKolli">
                                <span class="tp-dot"></span>
                                @(d.HalfKolli ? "Halv kasse tilladt" : "Ingen halv kasse")
                            </button>
                        </div>
                    </div>

                    <div class="detail-section">
                        <p class="detail-section-label">Titler</p>
                        <div class="ef-grid">
                            <EditableField Label="Octopus-titel"
                                           DisplayValue="@d.OctopusTitle"
                                           InputValue="@d.OctopusTitle"
                                           IsEditing="@(_editingField == "OctopusTitle")"
                                           IsDirty="@FieldDirty("OctopusTitle")"
                                           OnBeginEdit='@(() => BeginEdit("OctopusTitle"))'
                                           OnEndEdit="EndEdit"
                                           OnInput="@(v => d.OctopusTitle = v ?? "")" />

                            <EditableField Label="Web-titel"
                                           DisplayValue="@d.WebTitle"
                                           InputValue="@d.WebTitle"
                                           IsEditing="@(_editingField == "WebTitle")"
                                           IsDirty="@FieldDirty("WebTitle")"
                                           OnBeginEdit='@(() => BeginEdit("WebTitle"))'
                                           OnEndEdit="EndEdit"
                                           OnInput="@(v => d.WebTitle = v ?? "")" />

                            <EditableField Label="PDF-titel"
                                           DisplayValue="@d.PdfTitle"
                                           InputValue="@d.PdfTitle"
                                           IsEditing="@(_editingField == "PdfTitle")"
                                           IsDirty="@FieldDirty("PdfTitle")"
                                           IsMissing="@string.IsNullOrWhiteSpace(d.PdfTitle)"
                                           OnBeginEdit='@(() => BeginEdit("PdfTitle"))'
                                           OnEndEdit="EndEdit"
                                           OnInput="@(v => d.PdfTitle = v ?? "")" />

                            <EditableSelect Label="Kategori"
                                            Options="_allCats"
                                            DisplayValue="@d.Category"
                                            InputValue="@d.Category"
                                            IsEditing="@(_editingField == "Category")"
                                            IsDirty="@FieldDirty("Category")"
                                            OnBeginEdit='@(() => BeginEdit("Category"))'
                                            OnEndEdit="EndEdit"
                                            OnInput="@(v => d.Category = v ?? "")" />

                            <EditableField Label="Web ID"
                                           DisplayValue="@d.WebId.ToString()"
                                           InputValue="@d.WebId.ToString()"
                                           InputType="number"
                                           IsEditing="@(_editingField == "WebId")"
                                           IsDirty="@FieldDirty("WebId")"
                                           OnBeginEdit='@(() => BeginEdit("WebId"))'
                                           OnEndEdit="EndEdit"
                                           OnInput="@(v => { if (int.TryParse(v, out var n)) d.WebId = n; })" />
                        </div>
                    </div>

                    <div class="detail-section">
                        <p class="detail-section-label">Specifikationer</p>
                        <div class="ef-grid">
                            <EditableField Label="Størrelse (L)"
                                           DisplayValue="@(d.Str.ToString("0.##", CultureInfo.InvariantCulture) + " L")"
                                           InputValue="@d.Str.ToString(CultureInfo.InvariantCulture)"
                                           InputType="number" Step="0.01"
                                           IsEditing="@(_editingField == "Str")"
                                           IsDirty="@FieldDirty("Str")"
                                           OnBeginEdit='@(() => BeginEdit("Str"))'
                                           OnEndEdit="EndEdit"
                                           OnInput="@(v => { if (double.TryParse(v, NumberStyles.Any, CultureInfo.InvariantCulture, out var n)) d.Str = n; else if (string.IsNullOrWhiteSpace(v)) d.Str = 0; })" />

                            <EditableField Label="Alkohol %"
                                           DisplayValue="@(d.Alcohol.ToString("0.##", CultureInfo.InvariantCulture) + " %")"
                                           InputValue="@d.Alcohol.ToString(CultureInfo.InvariantCulture)"
                                           InputType="number" Step="0.1"
                                           IsEditing="@(_editingField == "Alcohol")"
                                           IsDirty="@FieldDirty("Alcohol")"
                                           OnBeginEdit='@(() => BeginEdit("Alcohol"))'
                                           OnEndEdit="EndEdit"
                                           OnInput="@(v => { if (double.TryParse(v, NumberStyles.Any, CultureInfo.InvariantCulture, out var n)) d.Alcohol = n; else if (string.IsNullOrWhiteSpace(v)) d.Alcohol = 0; })" />

                            <EditableField Label="Pris pr. enhed"
                                           DisplayValue="@(d.PricePrUnit.ToString("0.00", CultureInfo.InvariantCulture) + " kr")"
                                           InputValue="@d.PricePrUnit.ToString(CultureInfo.InvariantCulture)"
                                           InputType="number" Step="0.01"
                                           IsEditing="@(_editingField == "PricePrUnit")"
                                           IsDirty="@FieldDirty("PricePrUnit")"
                                           IsMissing="@(d.PricePrUnit == 0)"
                                           OnBeginEdit='@(() => BeginEdit("PricePrUnit"))'
                                           OnEndEdit="EndEdit"
                                           OnInput="@(v => { if (double.TryParse(v, NumberStyles.Any, CultureInfo.InvariantCulture, out var n)) d.PricePrUnit = n; else if (string.IsNullOrWhiteSpace(v)) d.PricePrUnit = 0; })" />

                            <EditableField Label="Kasse / Kolli"
                                           DisplayValue="@(d.KegCollar?.ToString() ?? "")"
                                           InputValue="@(d.KegCollar?.ToString() ?? "")"
                                           InputType="number"
                                           IsEditing="@(_editingField == "KegCollar")"
                                           IsDirty="@FieldDirty("KegCollar")"
                                           IsMissing="@((d.KegCollar ?? 0) == 0)"
                                           OnBeginEdit='@(() => BeginEdit("KegCollar"))'
                                           OnEndEdit="EndEdit"
                                           OnInput="@(v => { if (string.IsNullOrWhiteSpace(v)) d.KegCollar = null; else if (int.TryParse(v, out var n)) d.KegCollar = n == 0 ? null : n; })" />
                        </div>
                    </div>

                    <div class="detail-section">
                        <p class="detail-section-label">Webshop-varianter</p>
                        <div class="ef-grid">
                            <EditableField Label="Variant 1"
                                           DisplayValue="@(d.VariantId1 == 0 ? "—" : d.VariantId1.ToString())"
                                           InputValue="@d.VariantId1.ToString()"
                                           InputType="number"
                                           IsEditing="@(_editingField == "VariantId1")"
                                           IsDirty="@FieldDirty("VariantId1")"
                                           OnBeginEdit='@(() => BeginEdit("VariantId1"))'
                                           OnEndEdit="EndEdit"
                                           OnInput="@(v => { if (int.TryParse(v, out var n)) d.VariantId1 = n; else if (string.IsNullOrWhiteSpace(v)) d.VariantId1 = 0; })" />

                            <EditableField Label="Variant 2"
                                           DisplayValue="@(d.VariantId2 == 0 ? "—" : d.VariantId2.ToString())"
                                           InputValue="@d.VariantId2.ToString()"
                                           InputType="number"
                                           IsEditing="@(_editingField == "VariantId2")"
                                           IsDirty="@FieldDirty("VariantId2")"
                                           OnBeginEdit='@(() => BeginEdit("VariantId2"))'
                                           OnEndEdit="EndEdit"
                                           OnInput="@(v => { if (int.TryParse(v, out var n)) d.VariantId2 = n; else if (string.IsNullOrWhiteSpace(v)) d.VariantId2 = 0; })" />
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(_saveError))
                    {
                        <div class="detail-section">
                            <p class="field-error">@_saveError</p>
                        </div>
                    }

                    <div class="detail-spacer"></div>

                    <div class="detail-danger">
                        @if (_confirmingDelete)
                        {
                            <div class="delete-confirm">
                                <p class="delete-confirm-text">
                                    Slet <strong>#@d.OctopusId @d.OctopusTitle</strong> permanent? Denne handling kan ikke fortrydes.
                                </p>
                                <div class="delete-confirm-actions">
                                    <button class="btn-ghost" type="button"
                                            @onclick="() => _confirmingDelete = false"
                                            disabled="@_deleting">Annuller</button>
                                    <button class="btn-danger" type="button"
                                            @onclick="DeleteSelected" disabled="@_deleting">
                                        @(_deleting ? "Sletter…" : "Ja, slet permanent")
                                    </button>
                                </div>
                            </div>
                        }
                        else
                        {
                            <button class="delete-trigger" type="button"
                                    @onclick="() => _confirmingDelete = true">
                                Slet produkt
                            </button>
                        }
                    </div>

                    @if (dirtyCount > 0 || _saving)
                    {
                        <div class="save-bar">
                            <span class="save-bar-text">
                                @if (_saving)
                                {
                                    <span>Gemmer @dirtyCount @(dirtyCount == 1 ? "ændring" : "ændringer")…</span>
                                }
                                else
                                {
                                    <span><strong>@dirtyCount</strong> @(dirtyCount == 1 ? "ændring" : "ændringer") ikke gemt</span>
                                }
                            </span>
                            <div class="save-bar-actions">
                                <button class="btn-ghost" type="button" @onclick="DiscardDraft" disabled="@_saving">Forkast</button>
                                <button class="btn-primary" type="button" @onclick="SaveDraft" disabled="@_saving">
                                    @(_saving ? "Gemmer…" : "Færdiggør")
                                </button>
                            </div>
                        </div>
                    }
                }
            </section>
        </div>
    }
</section>

@code {
    private List<Product> _products = [];
    private bool _loading = true;

    // Filters
    private string _search = "";
    private string _catFilter = "Alle";
    private string _statusFilter = "Alle";
    private readonly string[] _statusOptions = ["Alle", "Tilgængelig", "Udsolgt"];
    private string _inUseFilter = "Alle";
    private readonly string[] _inUseOptions = ["Alle", "I brug", "Ikke i brug"];
    private HashSet<string> _missingFilters = [];
    private bool _missingOpen;

    // Sort
    private string _sortKey = "OctopusId-asc";

    // Selection / edit
    private int? _selectedId;
    private Product? _original;
    private Product? _draft;
    private string? _editingField;
    private string _saveError = "";
    private bool _saving;
    private int? _pendingSwitchTo;

    // Delete
    private bool _confirmingDelete;
    private bool _deleting;

    private static readonly (string Key, string Label, Func<Product, bool> Check)[] MissingOptions =
    [
        ("PdfTitle",    "PDF-titel mangler",    p => string.IsNullOrWhiteSpace(p.PdfTitle)),
        ("KegCollar",   "Kasse/Kolli mangler",  p => (p.KegCollar ?? 0) == 0),
        ("PricePrUnit", "Pris mangler",         p => p.PricePrUnit == 0),
    ];

    private static readonly (string Key, string Label)[] SortOptions =
    [
        ("OctopusId-asc",  "Octopus ID ↑"),
        ("OctopusId-desc", "Octopus ID ↓"),
        ("Title-asc",      "Titel A→Å"),
        ("Title-desc",     "Titel Å→A"),
        ("Available-asc",  "Disponibel ↑"),
        ("Available-desc", "Disponibel ↓"),
        ("Category-asc",   "Kategori A→Å"),
    ];

    private IEnumerable<string> _allCats => _products
        .Select(p => p.Category)
        .Where(c => !string.IsNullOrWhiteSpace(c))
        .Distinct()
        .OrderBy(c => c);

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _products = await ProductService.ListProducts();
        _loading = false;
        var first = SortProducts(_products).FirstOrDefault();
        if (first != null) DoSelect(first.OctopusId);
    }

    private List<Product> FilteredProducts()
    {
        IEnumerable<Product> q = _products;

        if (!string.IsNullOrWhiteSpace(_search))
        {
            var s = _search.Trim();
            q = q.Where(p =>
                p.OctopusId.ToString().Contains(s, StringComparison.OrdinalIgnoreCase) ||
                p.WebId.ToString().Contains(s, StringComparison.OrdinalIgnoreCase) ||
                (p.WebTitle ?? "").Contains(s, StringComparison.OrdinalIgnoreCase) ||
                (p.OctopusTitle ?? "").Contains(s, StringComparison.OrdinalIgnoreCase) ||
                (p.PdfTitle ?? "").Contains(s, StringComparison.OrdinalIgnoreCase) ||
                (p.Category ?? "").Contains(s, StringComparison.OrdinalIgnoreCase));
        }

        if (_catFilter != "Alle")
            q = q.Where(p => p.Category == _catFilter);

        if (_statusFilter == "Tilgængelig")
            q = q.Where(p => p.Status == ProductStatus.Available);
        else if (_statusFilter == "Udsolgt")
            q = q.Where(p => p.Status == ProductStatus.SoldOut);

        if (_inUseFilter == "I brug")
            q = q.Where(p => p.InUse);
        else if (_inUseFilter == "Ikke i brug")
            q = q.Where(p => !p.InUse);

        if (_missingFilters.Count > 0)
        {
            var checks = MissingOptions.Where(o => _missingFilters.Contains(o.Key)).ToArray();
            q = q.Where(p => checks.All(c => c.Check(p)));
        }

        return SortProducts(q).ToList();
    }

    private IEnumerable<Product> SortProducts(IEnumerable<Product> src) => _sortKey switch
    {
        "OctopusId-asc"  => src.OrderBy(p => p.OctopusId),
        "OctopusId-desc" => src.OrderByDescending(p => p.OctopusId),
        "Title-asc"      => src.OrderBy(p => p.OctopusTitle ?? ""),
        "Title-desc"     => src.OrderByDescending(p => p.OctopusTitle ?? ""),
        "Available-asc"  => src.OrderBy(p => p.Available),
        "Available-desc" => src.OrderByDescending(p => p.Available),
        "Category-asc"   => src.OrderBy(p => p.Category ?? "").ThenBy(p => p.OctopusTitle ?? ""),
        _                => src,
    };

    private void ToggleMissingOpen() => _missingOpen = !_missingOpen;

    private void ToggleMissing(string key)
    {
        if (!_missingFilters.Add(key)) _missingFilters.Remove(key);
    }

    private void ClearMissing() => _missingFilters.Clear();

    // ── Selection ─────────────────────────────────────────────────────────
    private void SelectProduct(int id)
    {
        if (_selectedId == id) return;
        if (DirtyFieldCount() > 0)
        {
            _pendingSwitchTo = id;
            return;
        }
        DoSelect(id);
    }

    private void DoSelect(int id)
    {
        var p = _products.FirstOrDefault(x => x.OctopusId == id);
        if (p == null) return;
        _selectedId = id;
        _original = Clone(p);
        _draft = Clone(p);
        _editingField = null;
        _saveError = "";
        _pendingSwitchTo = null;
        _confirmingDelete = false;
    }

    private void ConfirmSwitchDiscard()
    {
        if (_pendingSwitchTo.HasValue) DoSelect(_pendingSwitchTo.Value);
    }

    private void CancelSwitch() => _pendingSwitchTo = null;

    // ── Click-to-edit ─────────────────────────────────────────────────────
    private void BeginEdit(string field)
    {
        if (_draft == null) return;
        _editingField = field;
    }

    private void EndEdit()
    {
        _editingField = null;
    }

    private void ToggleInUse()
    {
        if (_draft == null) return;
        _draft.InUse = !_draft.InUse;
    }

    private void ToggleHalfKolli()
    {
        if (_draft == null) return;
        _draft.HalfKolli = !_draft.HalfKolli;
    }

    // ── Dirty tracking ────────────────────────────────────────────────────
    private bool FieldDirty(string field)
    {
        if (_draft == null || _original == null) return false;
        return field switch
        {
            "OctopusTitle" => _draft.OctopusTitle != _original.OctopusTitle,
            "WebTitle"     => _draft.WebTitle != _original.WebTitle,
            "PdfTitle"     => _draft.PdfTitle != _original.PdfTitle,
            "Category"     => _draft.Category != _original.Category,
            "WebId"        => _draft.WebId != _original.WebId,
            "Available"    => _draft.Available != _original.Available,
            "Str"          => Math.Abs(_draft.Str - _original.Str) > 1e-9,
            "Alcohol"      => Math.Abs(_draft.Alcohol - _original.Alcohol) > 1e-9,
            "PricePrUnit"  => Math.Abs(_draft.PricePrUnit - _original.PricePrUnit) > 1e-9,
            "KegCollar"    => (_draft.KegCollar ?? 0) != (_original.KegCollar ?? 0),
            "VariantId1"   => _draft.VariantId1 != _original.VariantId1,
            "VariantId2"   => _draft.VariantId2 != _original.VariantId2,
            "InUse"        => _draft.InUse != _original.InUse,
            "HalfKolli"    => _draft.HalfKolli != _original.HalfKolli,
            _              => false,
        };
    }

    private static readonly string[] AllFields =
    [
        "OctopusTitle", "WebTitle", "PdfTitle", "Category", "WebId",
        "Available", "Str", "Alcohol", "PricePrUnit", "KegCollar",
        "VariantId1", "VariantId2", "InUse", "HalfKolli"
    ];

    private int DirtyFieldCount() => AllFields.Count(FieldDirty);

    private void DiscardDraft()
    {
        if (_original == null) return;
        _draft = Clone(_original);
        _editingField = null;
        _saveError = "";
    }

    private async Task DeleteSelected()
    {
        if (_draft == null) return;
        var idToRemove = _draft.OctopusId;
        _deleting = true;
        _saveError = "";
        try
        {
            await ProductService.DeleteAsync(idToRemove);
            _products = await ProductService.ListProducts();
            _confirmingDelete = false;
            _draft = null;
            _original = null;
            _selectedId = null;
            var next = SortProducts(_products).FirstOrDefault();
            if (next != null) DoSelect(next.OctopusId);
        }
        catch (Exception ex)
        {
            _saveError = $"Kunne ikke slette: {ex.Message}";
        }
        finally
        {
            _deleting = false;
        }
    }

    private async Task SaveDraft()
    {
        if (_draft == null) return;
        _saving = true;
        _saveError = "";
        try
        {
            await ProductService.UpdateAsync(_draft);
            _products = await ProductService.ListProducts();
            var dbCopy = _products.FirstOrDefault(p => p.OctopusId == _draft.OctopusId);
            if (dbCopy != null)
            {
                _original = Clone(dbCopy);
                _draft = Clone(dbCopy);
            }
        }
        catch (Exception ex)
        {
            _saveError = $"Kunne ikke gemme: {ex.Message}";
        }
        finally
        {
            _saving = false;
        }
    }

    private static Product Clone(Product p) => new()
    {
        OctopusId    = p.OctopusId,
        WebId        = p.WebId,
        WebTitle     = p.WebTitle,
        PdfTitle     = p.PdfTitle,
        OctopusTitle = p.OctopusTitle,
        Available    = p.Available,
        KegCollar    = p.KegCollar,
        Str          = p.Str,
        Alcohol      = p.Alcohol,
        PricePrUnit  = p.PricePrUnit,
        Category     = p.Category,
        VariantId1   = p.VariantId1,
        VariantId2   = p.VariantId2,
        InUse        = p.InUse,
        HalfKolli    = p.HalfKolli,
    };
}
